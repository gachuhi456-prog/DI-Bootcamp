// Arrow function transformation
const winBattle = () => true;

const experiencePoints = winBattle() ? 10 : 1;

console.log(experiencePoints);  // Output: 10



const isString = (value) => typeof value === 'string';

console.log(isString('hello'));      // true
console.log(isString([1, 2, 4, 0])); // false
console.log(isString(123));          // false
console.log(isString('123'));        // true


const sum = (a, b) => a + b;

console.log(sum(5, 3));   // 8
console.log(sum(10, 20)); // 30


// Function Declaration (hoisted, can be called before definition)
function kgToGramsDeclaration(kg) {
    return kg * 1000;
}
console.log(kgToGramsDeclaration(5));  // 5000

// Function Expression (not hoisted, must be defined before calling)
const kgToGramsExpression = function(kg) {
    return kg * 1000;
};
console.log(kgToGramsExpression(3));   // 3000

// DIFFERENCE: Function declarations are hoisted (available throughout the scope), 
// while function expressions are not hoisted and only available after definition.

// Arrow Function (one line)
const kgToGramsArrow = kg => kg * 1000;
console.log(kgToGramsArrow(2));        // 2000


// Self-invoking function (IIFE) - runs immediately
(function(numChildren, partnerName, location, jobTitle) {
    const sentence = `You will be a ${jobTitle} in ${location}, and married to ${partnerName} with ${numChildren} kids.`;
    document.body.innerHTML += `<p>${sentence}</p>`;
})(3, "Alex", "Paris", "Software Engineer");


// Self-invoking function for user welcome
(function(userName) {
    const navbar = document.getElementById('navbar');
    
    const userDiv = document.createElement('div');
    userDiv.innerHTML = `
        <span>Welcome, ${userName}</span>
        <img src="https://via.placeholder.com/40" alt="Profile" style="border-radius: 50%; margin-left: 10px;">
    `;
    userDiv.style.display = 'flex';
    userDiv.style.alignItems = 'center';
    
    navbar.appendChild(userDiv);
})("John");


// Part I & II Combined
function makeJuice(size) {
    const ingredients = [];  // Empty array to store ingredients
    
    function addIngredients(ing1, ing2, ing3) {
        ingredients.push(ing1, ing2, ing3);
    }
    
    function displayJuice() {
        const sentence = `The client wants a ${size} juice, containing ${ingredients.join(', ')}`;
        document.body.innerHTML += `<p>${sentence}</p>`;
    }
    
    // Add ingredients twice (6 total)
    addIngredients('apple', 'banana', 'orange');
    addIngredients('spinach', 'ginger', 'lemon');
    
    // Display the final juice
    displayJuice();
}

// Invoke in global scope
makeJuice('large');