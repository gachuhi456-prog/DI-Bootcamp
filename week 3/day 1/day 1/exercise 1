// ==========================================
// 🌟 Exercise 1 : List of people
// ==========================================
const people = ["Greg", "Mary", "Devon", "James"];

// Part I - Review about arrays

// 1. Write code to remove “Greg” from the people array.
people.shift(); 
// people is now ["Mary", "Devon", "James"]

// 2. Write code to replace “James” to “Jason”.
people[2] = "Jason";
// people is now ["Mary", "Devon", "Jason"]

// 3. Write code to add your name to the end of the people array.
people.push("YourName"); 
// people is now ["Mary", "Devon", "Jason", "YourName"]

// 4. Write code that console.logs Mary’s index.
console.log("Mary's index:", people.indexOf("Mary"));

// 5. Write code to make a copy of the people array using the slice method.
// The copy should NOT include “Mary” or your name.
// Current array: ["Mary", "Devon", "Jason", "YourName"]
// We want elements from index 1 up to (but not including) index 3.
const peopleCopy = people.slice(1, 3);
console.log("Copy of array (no Mary/YourName):", peopleCopy);

// 6. Write code that gives the index of “Foo”. Why does it return -1 ?
console.log("Index of 'Foo':", people.indexOf("Foo")); 
// It returns -1 because "Foo" does not exist in the array.

// 7. Create a variable called last which value is the last element of the array.
const last = people[people.length - 1];
console.log("Last element:", last);

// Part II - Loops

// 1. Using a loop, iterate through the people array and console.log each person.
console.log("--- Full Loop ---");
for (let i = 0; i < people.length; i++) {
    console.log(people[i]);
}

// 2. Using a loop, iterate through the people array and exit after you console.log “Devon”.
console.log("--- Break Loop ---");
for (let i = 0; i < people.length; i++) {
    console.log(people[i]);
    if (people[i] === "Devon") {
        break;
    }
}


