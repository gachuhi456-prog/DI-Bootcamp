// ==========================================
const details = {
  my: 'name',
  is: 'Rudolf',
  the: 'reindeer'
};

let sentence = "";
for (let key in details) {
    sentence += `${key} ${details[key]} `;
}
console.log(sentence.trim()); // Output: "my name is Rudolf the reindeer"


// ==========================================
// Exercise 7 : Secret Group
// ==========================================
const names = ["Jack", "Philip", "Sarah", "Amanda", "Bernard", "Kyle"];

// 1. Map names to first letters
// 2. Sort the letters alphabetically
// 3. Join them into a string
const secretName = names
    .map(name => name[0])
    .sort()
    .join("");

console.log("Secret Society Name:", secretName); // Output: "ABJKPS"