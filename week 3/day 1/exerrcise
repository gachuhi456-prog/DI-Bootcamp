const names = ["Jack", "Philip", "Sarah", "Amanda", "Bernard", "Kyle"];

// Get first letter of each name
let firstLetters = "";

for (let i = 0; i < names.length; i++) {
    firstLetters += names[i][0]; // names[i].charAt(0) also works
}

// Sort alphabetically and convert to uppercase (though they're already uppercase)
let secretName = firstLetters.split('').sort().join('');

console.log(secretName); // "ABJKPS"