const people = ["Greg", "Mary", "Devon", "James"];

// Part I - Review about arrays

// 1. Remove "Greg" from the people array
people.shift();
console.log("After removing Greg:", people);

// 2. Replace "James" to "Jason"
people[people.length - 1] = "Jason";
console.log("After replacing James:", people);

// 3. Add your name to the end of the people array
people.push("YourName"); // Replace with your actual name
console.log("After adding my name:", people);

// 4. Console.log Mary's index
console.log("Mary's index:", people.indexOf("Mary"));

// 5. Make a copy using slice (NOT including "Mary" or your name)
// Current: ["Mary", "Devon", "Jason", "YourName"]
// Slice from index 1 to 3 (excludes index 3)
let peopleCopy = people.slice(1, 3);
console.log("Copy without Mary and my name:", peopleCopy);

// 6. Index of "Foo"
console.log("Index of Foo:", people.indexOf("Foo")); 
// Returns -1 because "Foo" doesn't exist in the array

// 7. Create variable 'last' with the last element
let last = people[people.length - 1];
console.log("Last element:", last);

// Part II - Loops

// Iterate through people array and console.log each person
console.log("\nAll people:");
for (let i = 0; i < people.length; i++) {
    console.log(people[i]);
}

// Iterate and exit after "Devon"
console.log("\nUntil Devon:");
for (let i = 0; i < people.length; i++) {
    console.log(people[i]);
    if (people[i] === "Devon") {
        break;
    }
}


