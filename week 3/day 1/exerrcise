// Prompt for a number (runs in browser, use readline in Node.js)
let number = prompt("Enter a number:");
console.log("Type:", typeof number); // "string"

// Convert to number
number = Number(number);

// While loop - continues while number is smaller than 10
while (number < 10) {
    number = Number(prompt("Enter a new number (must be >= 10):"));
}


