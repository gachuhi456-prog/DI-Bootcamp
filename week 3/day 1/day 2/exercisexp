function displayNumbersDivisible(divisor = 23) {
    let sum = 0;
    let output = "";

    for (let i = 0; i <= 500; i++) {
        if (i % divisor === 0) {
            output += i + " ";
            sum += i;
        }
    }

    console.log(output.trim()); // Logs the numbers separated by spaces
    console.log("Sum :", sum);
}

// Basic usage
displayNumbersDivisible();

// Bonus usage
displayNumbersDivisible(3);
displayNumbersDivisible(45);


const stock = { 
    "banana": 6, 
    "apple": 0,
    "pear": 12,
    "orange": 32,
    "blueberry":1
}  

const prices = {    
    "banana": 4, 
    "apple": 2, 
    "pear": 1,
    "orange": 1.5,
    "blueberry":10
} 

const shoppingList = ["banana", "orange", "apple"];

function myBill() {
    let totalPrice = 0;

    for (let item of shoppingList) {
        // Check if item is in stock
        if (stock[item] > 0) {
            let price = prices[item];
            totalPrice += price;

            // Bonus: Decrease stock by 1
            stock[item] -= 1;
        }
    }
    
    console.log("Total Price:", totalPrice);
    return totalPrice;
}

myBill();


function changeEnough(itemPrice, amountOfChange) {
    // amountOfChange order: quarters, dimes, nickels, pennies
    const quarters = amountOfChange[0] * 0.25;
    const dimes = amountOfChange[1] * 0.10;
    const nickels = amountOfChange[2] * 0.05;
    const pennies = amountOfChange[3] * 0.01;

    const totalChange = quarters + dimes + nickels + pennies;

    return totalChange >= itemPrice;
}

// Examples
console.log(changeEnough(4.25, [25, 20, 5, 0])); // returns true
console.log(changeEnough(14.11, [2,100,0,0])); // returns false
console.log(changeEnough(0.75, [0,0,20,5]));   // returns true


function hotelCost() {
    let nights;
    while (true) {
        nights = prompt("How many nights would you like to stay?");
        if (nights !== null && !isNaN(nights) && nights.trim() !== "") {
            break;
        }
    }
    return nights * 140;
}

function planeRideCost() {
    let destination;
    while (true) {
        destination = prompt("Where are you going?");
        if (destination !== null && isNaN(destination) && destination.trim() !== "") {
            break;
        }
    }

    if (destination.toLowerCase() === "london") {
        return 183;
    } else if (destination.toLowerCase() === "paris") {
        return 220;
    } else {
        return 300;
    }
}

function rentalCarCost() {
    let days;
    while (true) {
        days = prompt("How many days would you like to rent the car?");
        if (days !== null && !isNaN(days) && days.trim() !== "") {
            break;
        }
    }

    let dailyCost = 40;
    let totalCost = days * dailyCost;

    if (days > 10) {
        totalCost = totalCost * 0.95; // Apply 5% discount
    }
    return totalCost;
}

function totalVacationCost() {
    const carCost = rentalCarCost();
    const hotelPrice = hotelCost();
    const planePrice = planeRideCost();

    console.log(`The car cost: $${carCost}, the hotel cost: $${hotelPrice}, the plane tickets cost: $${planePrice}.`);
    console.log(`Total Vacation Cost: $${carCost + hotelPrice + planePrice}`);
}

totalVacationCost();


