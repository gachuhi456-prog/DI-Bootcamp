const readline = require('readline');

const rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout
});

function askQuestion(question) {
    return new Promise((resolve) => {
        rl.question(question, (answer) => {
            resolve(answer);
        });
    });
}

async function hotelCost() {
    let nights;
    while (true) {
        nights = await askQuestion('How many nights would you like to stay? ');
        nights = parseInt(nights);
        if (!isNaN(nights) && nights > 0) break;
        console.log('Please enter a valid number.');
    }
    return nights * 140;
}

async function planeRideCost() {
    let destination;
    while (true) {
        destination = await askQuestion('What is your destination? ');
        if (typeof destination === 'string' && destination.trim() !== '') break;
        console.log('Please enter a valid destination.');
    }
    
    const prices = {
        'London': 183,
        'Paris': 220
    };
    return prices[destination] || 300;
}

async function rentalCarCost() {
    let days;
    while (true) {
        days = await askQuestion('How many days would you like to rent the car? ');
        days = parseInt(days);
        if (!isNaN(days) && days > 0) break;
        console.log('Please enter a valid number.');
    }
    
    let cost = days * 40;
    if (days > 10) {
        cost *= 0.95; // 5% discount
    }
    return cost;
}

async function totalVacationCost() {
    const hotel = await hotelCost();
    const plane = await planeRideCost();
    const car = await rentalCarCost();
    
    const total = hotel + plane + car;
    
    console.log(`The car cost: $${car.toFixed(2)}`);
    console.log(`The hotel cost: $${hotel.toFixed(2)}`);
    console.log(`The plane tickets cost: $${plane.toFixed(2)}`);
    console.log(`Total vacation cost: $${total.toFixed(2)}`);
    
    rl.close();
}

totalVacationCost();


