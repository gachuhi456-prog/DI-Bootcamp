console.log("--- Exercise 1: Conditional Types ---");

// 1. Define a Conditional Type
// If T is number, return number. If T is string, return number (the length).
type MappedType = T extends number ? number : T extends string ? number : never;

// 2. Implement the Function
function mapType(value: T): MappedType {
    if (typeof value === "number") {
        // Return the square of the value
        return value * value as MappedType;
    } else {
        // Return the length of the string
        return value.length as MappedType;
    }
}

// 3. Test the Function
const numResult = mapType(5);       // Input: number, Output: 25
const strResult = mapType("Hello"); // Input: string, Output: 5

console.log(`mapType(5): ${numResult}`);          // Output: 25
console.log(`mapType("Hello"): ${strResult}`);    // Output: 5


// ==========================================
// Exercise 2: Keyof and Lookup Types
// ==========================================
console.log("\n--- Exercise 2: Keyof and Lookup Types ---");

// 1. Define the Function
// K extends keyof T ensures 'key' is valid for 'obj'
// T[K] is the lookup type that returns the specific type of the property
function getProperty<T, K extends keyof T>(obj: T, key: K): T[K] {
    return obj[key];
}

// 2. Test the Function
const user = {
    id: 101,
    name: "Alice",
    isActive: true,
    role: "admin"
};

const userId = getProperty(user, "id");
const userName = getProperty(user, "name");
const userRole = getProperty(user, "role");

console.log(`User ID: ${userId}`);       // Output: 101
console.log(`User Name: ${userName}`);   // Output: Alice
console.log(`User Role: ${userRole}`);   // Output: admin

