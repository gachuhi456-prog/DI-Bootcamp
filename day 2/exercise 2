// ==========================================
console.log("\n--- Exercise 3: Interfaces with Numeric Properties ---");

// 1. Define an Interface
// This interface describes objects where any property accessed by a string key has a numeric value
interface HasNumericProperty {
    [key: string]: number;
}

// 2. Implement the Function
// Takes an object adhering to the interface, a specific property key, and a factor
function multiplyProperty(obj: HasNumericProperty, key: string, factor: number): number {
    const value = obj[key];
    return value * factor;
}

// 3. Test the Function
// Define an object that fits the interface (all property values are numbers)
const dimensions = {
    width: 10,
    height: 20,
    depth: 5
};

const area = multiplyProperty(dimensions, "width", 5);   // 10 * 5 = 50
const volume = multiplyProperty(dimensions, "depth", 10); // 5 * 10 = 50

console.log(`Width multiplied by 5: ${area}`);     // Output: 50
console.log(`Depth multiplied by 10: ${volume}`);  // Output: 50