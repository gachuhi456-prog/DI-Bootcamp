// ==========================================
// Exercise 1 : Promise.all()
// ==========================================

const promise1 = Promise.resolve(3);
const promise2 = 42;
const promise3 = new Promise((resolve, reject) => {
  setTimeout(resolve, 3000, 'foo');
});

/* 
   EXPLANATION: How Promise.all works
   
   Promise.all takes an iterable of promises (like an array) and returns a single Promise.
   
   1. It waits for all promises in the array to resolve.
   2. The returned promise resolves with an array containing the fulfillment values of the 
      original promises, in the same order as the original promises (regardless of which 
      promise finished first).
   3. If any of the promises in the array are rejected, Promise.all immediately rejects 
      with the reason of the first rejected promise (this is known as "fail-fast").
   
   In this specific case:
   - promise1 resolves immediately with 3.
   - promise2 is not a promise, but Promise.all wraps it in a resolved promise with value 42.
   - promise3 resolves after 3 seconds with 'foo'.
   
   The function waits for promise3 to finish before outputting the final array.
*/

Promise.all([promise1, promise2, promise3])
  .then((values) => {
    console.log("Exercise 1 Output:", values);
  })
  .catch((error) => {
    console.error("Exercise 1 Error:", error);
  });


