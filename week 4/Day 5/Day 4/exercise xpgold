// Exercise 2 : Analyse Promise.all()
// ==========================================

function timesTwoAsync(x) {
  return new Promise(resolve => resolve(x * 2));
}

const arr = [1, 2, 3];
const promiseArr = arr.map(timesTwoAsync);

/*
   ANALYSIS:
   
   1. `arr` contains [1, 2, 3].
   2. `arr.map(timesTwoAsync)` creates a new array by calling `timesTwoAsync` on each element.
      - timesTwoAsync(1) -> Returns a Promise resolving to 2
      - timesTwoAsync(2) -> Returns a Promise resolving to 4
      - timesTwoAsync(3) -> Returns a Promise resolving to 6
   3. `promiseArr` is now an array of 3 Promises: [Promise<2>, Promise<4>, Promise<6>].
   4. `Promise.all(promiseArr)` waits for all of these to resolve.
   5. Once resolved, the .then block receives the result array [2, 4, 6].
   
   EXPECTED OUTPUT: [2, 4, 6]
*/

Promise.all(promiseArr)
  .then(result => {
    console.log("Exercise 2 Output:", result);
  });