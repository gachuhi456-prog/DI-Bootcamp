const colors = ["Blue", "Green", "Red", "Orange", "Violet", "Indigo", "Yellow"];

// Part 1: Display colors with ordinal numbers
colors.forEach((color, index) => {
    console.log(`${index + 1}# choice is ${color}.`);
});

// Part 2: Check if "Violet" exists in the array
const hasViolet = colors.some(color => color === "Violet");
console.log(hasViolet ? "Yeah" : "No...");


const colors = ["Blue", "Green", "Red", "Orange", "Violet", "Indigo", "Yellow"];
const ordinal = ["th", "st", "nd", "rd"];

colors.forEach((color, index) => {
    const position = index + 1;
    // Use ternary operator to determine correct ordinal suffix
    const suffix = position <= 3 ? ordinal[position] : ordinal[0];
    console.log(`${position}${suffix} choice is ${color}.`);
});


