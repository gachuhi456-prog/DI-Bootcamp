SELECT rating, COUNT(*) AS total_films
FROM film
GROUP BY rating
ORDER BY rating;

SELECT title, rating
FROM film
WHERE rating IN ('G', 'PG-13');

SELECT title, rating, length, rental_rate
FROM film
WHERE rating IN ('G', 'PG-13')
AND length < 120
AND rental_rate < 3.00
ORDER BY title ASC;

UPDATE customer
SET first_name = 'Alex',
    last_name = 'Nairobi'
WHERE customer_id = 1;

UPDATE address
SET address = '123 Nairobi Street'
WHERE address_id = (
    SELECT address_id 
    FROM customer 
    WHERE customer_id = 1
);

