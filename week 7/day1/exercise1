const express = require('express');
const router = express.Router();

// In-memory data store
let posts = [];
let currentId = 1;

// Model Helper: Create a post object
function createPost(title, content) {
    return {
        id: currentId++,
        title: title,
        content: content,
        timestamp: new Date().toISOString()
    };
}

// Validation Helper
function validatePostInput(req, res, next) {
    const { title, content } = req.body;
    
    if (!title || !content) {
        return res.status(400).json({ 
            error: 'Validation Error: Title and Content are required.' 
        });
    }
    next();
}

// GET /posts: Retrieve a list of all blog posts
router.get('/', (req, res) => {
    res.status(200).json(posts);
});

// GET /posts/:id: Retrieve a specific blog post by ID
router.get('/:id', (req, res) => {
    const id = parseInt(req.params.id);
    const post = posts.find(p => p.id === id);

    if (!post) {
        return res.status(404).json({ error: 'Post not found.' });
    }

    res.status(200).json(post);
});

// POST /posts: Create a new blog post
router.post('/', validatePostInput, (req, res) => {
    const { title, content } = req.body;
    const newPost = createPost(title, content);
    posts.push(newPost);
    
    res.status(201).json(newPost);
});

// PUT /posts/:id: Update a blog post by ID
router.put('/:id', validatePostInput, (req, res) => {
    const id = parseInt(req.params.id);
    const postIndex = posts.findIndex(p => p.id === id);

    if (postIndex === -1) {
        return res.status(404).json({ error: 'Post not found.' });
    }

    // Update the post
    const updatedPost = {
        ...posts[postIndex],
        title: req.body.title,
        content: req.body.content,
        timestamp: new Date().toISOString() // Update timestamp
    };

    posts[postIndex] = updatedPost;
    res.status(200).json(updatedPost);
});

// DELETE /posts/:id: Delete a blog post by ID
router.delete('/:id', (req, res) => {
    const id = parseInt(req.params.id);
    const postIndex = posts.findIndex(p => p.id === id);

    if (postIndex === -1) {
        return res.status(404).json({ error: 'Post not found.' });
    }

    // Remove post from array
    posts.splice(postIndex, 1);
    res.status(204).send(); // 204 No Content is standard for successful deletion
});

module.exports = router;

const express = require('express');
const app = express();
const postRoutes = require('./routes/posts');

// Middleware to parse JSON bodies
app.use(express.json());

// Mount the router
// The routes defined in posts.js will be available under /posts
app.use('/posts', postRoutes);

// Root route
app.get('/', (req, res) => {
    res.send('Blog API is running. Use /posts endpoints.');
});

// Error handling middleware (optional but good practice)
app.use((err, req, res, next) => {
    console.error(err.stack);
    res.status(500).json({ error: 'Something went wrong!' });
});

// Start the server
const PORT = 3000;
app.listen(PORT, () => {
    console.log(`Server is running on http://localhost:${PORT}`);
});

node app.

