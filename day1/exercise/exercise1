const express = require('express');
const postsRouter = require('./routes/posts');

const app = express();
const PORT = 3000;

// Middleware to parse JSON bodies (Required for POST and PUT)
app.use(express.json());

// Mount the router at /posts
app.use('/posts', postsRouter);

// Start the server
app.listen(PORT, () => {
    console.log(`Blog API running at http://localhost:${PORT}`);
});

const express = require('express');
const router = express.Router();

// In-memory database
let posts = [];
let nextId = 1;

// 1. GET /posts: Retrieve all blog posts
router.get('/', (req, res) => {
    res.json(posts);
});

// 2. GET /posts/:id: Retrieve a specific blog post
router.get('/:id', (req, res) => {
    const id = parseInt(req.params.id);
    const post = posts.find(p => p.id === id);

    if (!post) {
        return res.status(404).json({ error: "Blog post not found" });
    }

    res.json(post);
});

// 3. POST /posts: Create a new blog post
router.post('/', (req, res) => {
    const { title, content } = req.body;

    // Validation: Ensure title and content exist
    if (!title || !content) {
        return res.status(400).json({ error: "Title and Content are required" });
    }

    const newPost = {
        id: nextId++,
        title: title,
        content: content,
        timestamp: new Date().toISOString() // Store current date/time
    };

    posts.push(newPost);
    // 201 Created status code
    res.status(201).json(newPost);
});

// 4. PUT /posts/:id: Update a blog post
router.put('/:id', (req, res) => {
    const id = parseInt(req.params.id);
    const post = posts.find(p => p.id === id);

    if (!post) {
        return res.status(404).json({ error: "Blog post not found" });
    }

    const { title, content } = req.body;

    // Validation: Ensure at least one field is provided to update
    if (!title && !content) {
        return res.status(400).json({ error: "Please provide title or content to update" });
    }

    // Update fields if provided
    if (title) post.title = title;
    if (content) post.content = content;
    
    // Update timestamp to reflect the edit
    post.timestamp = new Date().toISOString();

    res.json(post);
});

// 5. DELETE /posts/:id: Delete a blog post
router.delete('/:id', (req, res) => {
    const id = parseInt(req.params.id);
    const index = posts.findIndex(p => p.id === id);

    if (index === -1) {
        return res.status(404).json({ error: "Blog post not found" });
    }

    // Remove the post from the array
    posts.splice(index, 1);

    res.json({ message: "Blog post deleted successfully" });
});

