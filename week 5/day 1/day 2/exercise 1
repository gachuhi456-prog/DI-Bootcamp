console.log("--- Exercise 1: Union Types ---");

function processValue(input: string | number): string {
    if (typeof input === "number") {
        // Format number as currency (e.g., $100.00)
        return `$${input.toFixed(2)}`;
    } else {
        // Return the reversed string
        return input.split('').reverse().join('');
    }
}

// Test the Function
console.log(processValue(100));       // Output: $100.00
console.log(processValue(123.456));   // Output: $123.46
console.log(processValue("TypeScript")); // Output: tpircSepyT


