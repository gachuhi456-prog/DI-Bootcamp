console.log("\n--- Exercise 2: Array Type Annotations ---");

function sumNumbersInArray(arr: (number | string)[]): number {
    let sum = 0;
    
    for (const item of arr) {
        // Type guard: check if the item is a number
        if (typeof item === "number") {
            sum += item;
        }
    }
    
    return sum;
}

// Test the Function
const mixedArray1 = [10, "apple", 20, "banana", 30];
console.log(`Sum of [10, "apple", 20, "banana", 30]:`, sumNumbersInArray(mixedArray1)); // Output: 60

const mixedArray2 = ["only", "strings", "here"];
console.log(`Sum of ["only", "strings", "here"]:`, sumNumbersInArray(mixedArray2)); // Output: 0


