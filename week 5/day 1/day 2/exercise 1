console.log("\n--- Exercise 4: Optional Parameters ---");

function welcomeUser(name: string, greeting?: string): string {
    // Use conditional logic to apply default greeting if none is provided
    const finalGreeting = greeting ? greeting : "Hello";
    
    return `${finalGreeting}, ${name}!`;
}

// Test the Function
console.log(welcomeUser("Charlie"));                  // Output: Hello, Charlie!
console.log(welcomeUser("Dana", "Good morning"));     // Output: Good morning, Dana!