/*
 * NOTE: This exercise requires a DOM environment (like a web browser).
 * Since VS Code runs TypeScript in Node.js, 'document' is not defined.
 * The code below checks if 'document' exists to prevent crashes.
 */

if (typeof document !== 'undefined') {
    // Get an Element from the DOM
    const inputElement = document.getElementById("myInput") as HTMLInputElement;

    // Access the Element’s Properties
    if (inputElement) {
        inputElement.value = "Hello from TypeScript!";
        console.log("Input value set to:", inputElement.value);
    } else {
        console.log("Element with ID 'myInput' not found.");
    }
} else {
    console.log("Skipped Exercise 7 execution: DOM (document) is not available in Node.js environment.");
}


// ==========================================
// 🌟 Exercise 8: switch Statement
// ==========================================
console.log("\n--- Exercise 8: Switch Statement ---");

function getAction(role: string): string {
    switch (role) {
        case "admin":
            return "Manage users and settings";
        case "editor":
            return "Edit content";
        case "viewer":
            return "View content";
        case "guest":
            return "Limited access";
        default:
            return "Invalid role";
    }
}

// Testing the function
console.log("Role 'admin':", getAction("admin"));
console.log("Role 'editor':", getAction("editor"));
console.log("Role 'viewer':", getAction("viewer"));
console.log("Role 'guest':", getAction("guest"));
console.log("Role 'unknown':", getAction("unknown"));


// ==========================================
// 🌟 Exercise 9: Function Overloading
// ==========================================
console.log("\n--- Exercise 9: Function Overloading ---");

// 1. Define Overload Signatures
function greet(): string;
function greet(name: string): string;

// 2. Implementation
function greet(name?: string): string {
    if (name) {
        return `Hello, ${name}!`;
    }
    return "Hello, there!";
}

// Testing the overloaded function
console.log(greet("Alice")); // Output: Hello, Alice!
console.log(greet());        // Output: Hello, there!