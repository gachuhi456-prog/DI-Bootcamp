// 🌟 Exercise 4: Control Flow with if...else
// ==========================================
console.log("\n--- Exercise 4: Control Flow ---");

function checkNumberType(num: number): string {
    if (num > 0) {
        return "Positive";
    } else if (num < 0) {
        return "Negative";
    } else {
        return "Zero";
    }
}

console.log("Input: 10 ->", checkNumberType(10));
console.log("Input: -5 ->", checkNumberType(-5));
console.log("Input: 0 ->", checkNumberType(0));


