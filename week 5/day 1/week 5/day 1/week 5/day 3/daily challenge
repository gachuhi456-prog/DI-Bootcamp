// Interface Book definition
interface Book {
    title: string;
    author: string;
    isbn: string;
    publishedYear: number;
    genre?: string; // Optional property
}

// Base Library class
class Library {
    private books: Book[] = [];

    // Add a new book to the library
    public addBook(book: Book): void {
        // Check if book with same ISBN already exists
        const existingBook = this.books.find(b => b.isbn === book.isbn);
        if (existingBook) {
            console.log(`Book with ISBN ${book.isbn} already exists.`);
            return;
        }
        this.books.push(book);
        console.log(`Added: "${book.title}" by ${book.author}`);
    }

    // Get book details by ISBN
    public getBookDetails(isbn: string): string {
        const book = this.books.find(b => b.isbn === isbn);
        
        if (!book) {
            return `Book with ISBN ${isbn} not found.`;
        }

        const genreInfo = book.genre ? `Genre: ${book.genre}` : "Genre: Not specified";
        
        return `
Book Details:
-------------
Title: ${book.title}
Author: ${book.author}
ISBN: ${book.isbn}
Published Year: ${book.publishedYear}
${genreInfo}
        `.trim();
    }

    // Protected method to access books array in derived classes
    protected getAllBooks(): Book[] {
        return [...this.books]; // Return copy to maintain encapsulation
    }

    // Protected method to get books count
    protected getBooksCount(): number {
        return this.books.length;
    }
}

// DigitalLibrary extends Library
class DigitalLibrary extends Library {
    readonly website: string;

    constructor(website: string) {
        super();
        this.website = website;
    }

    // List all book titles
    public listBooks(): string[] {
        const books = this.getAllBooks();
        return books.map(book => book.title);
    }

    // Get library info including website
    public getLibraryInfo(): string {
        return `
Digital Library Information:
---------------------------
Website: ${this.website}
Total Books: ${this.getBooksCount()}
        `.trim();
    }

    // Override getBookDetails to include website info
    public getBookDetails(isbn: string): string {
        const baseDetails = super.getBookDetails(isbn);
        if (baseDetails.includes("not found")) {
            return baseDetails;
        }
        return `${baseDetails}\nLibrary Website: ${this.website}`;
    }

    // Print formatted catalog
    public printCatalog(): void {
        const books = this.getAllBooks();
        console.log("\n=== DIGITAL LIBRARY CATALOG ===");
        console.log(`Website: ${this.website}`);
        console.log("--------------------------------");
        
        if (books.length === 0) {
            console.log("No books in library.");
            return;
        }

        books.forEach((book, index) => {
            console.log(`${index + 1}. ${book.title} (${book.publishedYear})`);
        });
        
        console.log(`--------------------------------\nTotal: ${books.length} books\n`);
    }
}

