interface Product {
    readonly name: string;
    price: number;
    discount?: number; // Optional property
}

interface Electronics extends Product {
    warrantyPeriod: number; // in months
}

class Smartphone implements Electronics {
    readonly name: string;
    price: number;
    discount?: number;
    warrantyPeriod: number;
    brand: string;

    constructor(
        name: string,
        price: number,
        warrantyPeriod: number,
        brand: string,
        discount?: number
    ) {
        this.name = name;
        this.price = price;
        this.warrantyPeriod = warrantyPeriod;
        this.brand = brand;
        if (discount !== undefined) {
            this.discount = discount;
        }
    }

    calculateFinalPrice(): number {
        if (this.discount) {
            return this.price - (this.price * this.discount) / 100;
        }
        return this.price;
    }

    getProductDetails(): string {
        const finalPrice = this.calculateFinalPrice();
        const discountInfo = this.discount ? `${this.discount}% off` : "No discount";
        
        return `
Product: ${this.name}
Brand: ${this.brand}
Original Price: $${this.price}
Discount: ${discountInfo}
Final Price: $${finalPrice.toFixed(2)}
Warranty: ${this.warrantyPeriod} months
        `.trim();
    }

    updatePrice(newPrice: number): void {
        this.price = newPrice;
    }

    updateDiscount(newDiscount: number | undefined): void {
        this.discount = newDiscount;
    }

    // Cannot update name - it's readonly
    // updateName(newName: string): void {
    //     this.name = newName; // Error: Cannot assign to 'name' because it is a read-only property
    // }
}

