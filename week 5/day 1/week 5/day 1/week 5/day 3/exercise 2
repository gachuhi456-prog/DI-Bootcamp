class Device {
    readonly serialNumber: string;
    public manufacturer: string;

    constructor(serialNumber: string, manufacturer: string) {
        this.serialNumber = serialNumber;
        this.manufacturer = manufacturer;
    }

    getDeviceInfo(): string {
        return `Serial: ${this.serialNumber}, Manufacturer: ${this.manufacturer}`;
    }
}

class Laptop extends Device {
    model: string;
    price: number;
    private specs: string;

    constructor(
        serialNumber: string,
        manufacturer: string,
        model: string,
        price: number,
        specs: string
    ) {
        super(serialNumber, manufacturer);
        this.model = model;
        this.price = price;
        this.specs = specs;
    }

    // Override to include laptop-specific details
    getDeviceInfo(): string {
        return `${super.getDeviceInfo()}, Model: ${this.model}, Price: $${this.price}, Specs: ${this.specs}`;
    }

    updatePrice(newPrice: number): void {
        this.price = newPrice;
        console.log(`Price updated to $${this.price}`);
    }

    updateModel(newModel: string): void {
        this.model = newModel;
        console.log(`Model updated to ${this.model}`);
    }

    // Cannot update serialNumber - it's readonly
    // updateSerial(newSerial: string): void {
