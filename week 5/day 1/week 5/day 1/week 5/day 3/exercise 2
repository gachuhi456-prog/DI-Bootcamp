class Employee {
    public name: string;
    private age: number;
    protected salary: number;

    constructor(name: string, age: number, salary: number) {
        this.name = name;
        this.age = age;
        this.salary = salary;
    }

    // Protected method: accessible in derived classes, not from outside
    protected calculateBonus(): number {
        return this.salary * 0.1; // 10% bonus
    }

    public getSalaryDetails(): string {
        return `Base Salary: $${this.salary}`;
    }

    // Public getter for private age (controlled access)
    public getAge(): number {
        return this.age;
    }
}

class Manager extends Employee {
    constructor(name: string, age: number, salary: number) {
        super(name, age, salary);
    }

    // Override to include bonus calculation
    public getSalaryDetails(): string {
        const bonus = this.calculateBonus(); // Can access protected method
        return `${super.getSalaryDetails()}, Bonus: $${bonus.toFixed(2)}, Total: $${(this.salary + bonus).toFixed(2)}`;
    }

    // Manager-specific method
    public manageTeam(): string {
        return `${this.name} is managing a team.`;
    }
}

class ExecutiveManager extends Manager {
    private budgetApprovalLimit: number;

    constructor(name: string, age: number, salary: number, budgetApprovalLimit: number) {
        super(name, age, salary);
        this.budgetApprovalLimit = budgetApprovalLimit;
    }

    // New method specific to ExecutiveManager
    public approveBudget(amount: number): string {
        if (amount <= this.budgetApprovalLimit) {
            return `Budget of $${amount} approved by ${this.name}.`;
        } else {
            return `Budget of $${amount} exceeds approval limit of $${this.budgetApprovalLimit}.`;
        }
    }

    public getExecutiveDetails(): string {
        return `Executive: ${this.name}, Approval Limit: $${this.budgetApprovalLimit}`;
    }
}

