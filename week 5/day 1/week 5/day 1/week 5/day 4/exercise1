// Define User interface
interface User {
    name: string;
    email: string;
}

// Define Admin interface
interface Admin {
    adminLevel: number;
}

// Create intersection type combining both
type AdminUser = User & Admin;

// Function to get property with type guard
function getProperty(obj: AdminUser, propertyName: string): any | undefined {
    // Type guard: check if property exists on the object
    if (propertyName in obj) {
        return (obj as any)[propertyName];
    }
    return undefined;
}

// Test the implementation
const adminUser: AdminUser = {
    name: "John Doe",
    email: "john@example.com",
    adminLevel: 5
};

console.log(getProperty(adminUser, "name"));        // Output: "John Doe"
console.log(getProperty(adminUser, "email"));     // Output: "john@example.com"
console.log(getProperty(adminUser, "adminLevel")); // Output: 5
console.log(getProperty(adminUser, "nonexistent")); // Output: undefined

// Generic function that casts value to a specific type using constructor
function castToType<T>(value: any, constructor: new (value: any) => T): T {
    return new constructor(value);
}

// Demonstration: Cast string to number
const stringToNumber = castToType("42", Number);
console.log(stringToNumber);           // Output: 42 (number)
console.log(typeof stringToNumber);    // Output: "number"

// Demonstration: Cast string to boolean
const stringToBoolean = castToType("true", Boolean);
console.log(stringToBoolean);          // Output: true (boolean)
console.log(typeof stringToBoolean);   // Output: "boolean"

// Additional demonstration: Cast to String object
const stringToString = castToType(123, String);
console.log(stringToString);           // Output: "123" (String object)
console.log(typeof stringToString);    // Output: "object" (but wraps "123")

// Cast array to Date
const stringToDate = castToType("2024-01-01", Date);
console.log(stringToDate);             // Output: Date object

// Generic function with constraints - only accepts number or string arrays
function getArrayLength<T extends number | string>(arr: T[]): number {
    // Type assertion to ensure TypeScript treats it as array with length
    const arrayWithLength = arr as { length: number };
    return arrayWithLength.length;
}

// Test with number array
const numberArray: number[] = [1, 2, 3, 4, 5];
console.log(getArrayLength(numberArray));  // Output: 5

// Test with string array
const stringArray: string[] = ["a", "b", "c"];
console.log(getArrayLength(stringArray));  // Output: 3

// Test with empty array
const emptyArray: number[] = [];
console.log(getArrayLength(emptyArray));   // Output: 0

