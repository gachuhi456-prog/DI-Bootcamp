// Define generic interface Storage
interface Storage<T> {
    add(item: T): void;
    get(index: number): T | undefined;
}

// Implement the interface in a class Box
class Box<T> implements Storage<T> {
    private items: T[] = [];

    // Add item to storage
    add(item: T): void {
        this.items.push(item);
    }

    // Get item by index
    get(index: number): T | undefined {
        if (index >= 0 && index < this.items.length) {
            return this.items[index];
        }
        return undefined;
    }

    // Helper method to get all items (for testing)
    getAll(): T[] {
        return [...this.items];
    }
}

// Test with number type
const numberBox = new Box<number>();
numberBox.add(10);
numberBox.add(20);
numberBox.add(30);
console.log(numberBox.get(0));    // Output: 10
console.log(numberBox.get(1));    // Output: 20
console.log(numberBox.get(5));    // Output: undefined

// Test with string type
const stringBox = new Box<string>();
stringBox.add("Hello");
stringBox.add("World");
console.log(stringBox.get(0));    // Output: "Hello"
console.log(stringBox.get(1));    // Output: "World"

// Test with custom object type
interface Person {
    name: string;
    age: number;
}

const personBox = new Box<Person>();
personBox.add({ name: "Alice", age: 30 });
personBox.add({ name: "Bob", age: 25 });
console.log(personBox.get(0));    // Output: { name: "Alice", age: 30 }
console.log(personBox.get(1));    // Output: { name: "Bob", age: 25 }

// Define interface Item with value property
interface Item<T> {
    value: T;
}

// Generic class Queue with constraint that T must have value property
class Queue<T extends Item<any>> {
    private items: T[] = [];

    // Add item to queue
    add(item: T): void {
        this.items.push(item);
    }

    // Remove and return first item from queue
    remove(): T | undefined {
        return this.items.shift();
    }

    // Peek at first item without removing
    peek(): T | undefined {
        return this.items[0];
    }

    // Get queue size
    size(): number {
        return this.items.length;
    }

    // Check if queue is empty
    isEmpty(): boolean {
        return this.items.length === 0;
    }
}

// Test with number values
interface NumberItem extends Item<number> {
    value: number;
    label?: string;
}

const numberQueue = new Queue<NumberItem>();
numberQueue.add({ value: 100, label: "First" });
numberQueue.add({ value: 200, label: "Second" });
console.log(numberQueue.remove());  // Output: { value: 100, label: "First" }
console.log(numberQueue.size());    // Output: 1

// Test with string values
interface StringItem extends Item<string> {
    value: string;
    priority?: number;
}

const stringQueue = new Queue<StringItem>();
stringQueue.add({ value: "Task 1", priority: 1 });
stringQueue.add({ value: "Task 2", priority: 2 });
stringQueue.add({ value: "Task 3" });
console.log(stringQueue.remove());  // Output: { value: "Task 1", priority: 1 }
console.log(stringQueue.peek());    // Output: { value: "Task 2", priority: 2 }
console.log(stringQueue.size());    // Output: 2

// Test with complex object values
interface ProductItem extends Item<{ id: number; name: string }> {
    value: { id: number; name: string };
    category: string;
}

const productQueue = new Queue<ProductItem>();
productQueue.add({ 
    value: { id: 1, name: "Laptop" }, 
    category: "Electronics" 
});
productQueue.add({ 
    value: { id: 2, name: "Mouse" }, 
    category: "Accessories" 
});

console.log(productQueue.remove()); // Output: { value: { id: 1, name: "Laptop" }, category: "Electronics" }
console.log(productQueue.isEmpty()); // Output: false