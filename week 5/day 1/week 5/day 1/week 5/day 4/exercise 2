// Generic interface for API responses
interface Response<T> {
    status: number;
    message: string;
    data: T;
    timestamp: string;
}

// User data type
interface UserData {
    id: number;
    username: string;
    email: string;
}

// Product data type
interface ProductData {
    sku: string;
    name: string;
    price: number;
    inStock: boolean;
}

// Function to parse and cast response data
function parseResponse<T>(response: Response<any>, typeGuard?: (data: any) => data is T): Response<T> {
    // Cast the data to the desired type T
    const castedData = response.data as T;
    
    // Return new response with casted data
    const parsedResponse: Response<T> = {
        status: response.status,
        message: response.message,
        data: castedData,
        timestamp: response.timestamp
    };
    
    return parsedResponse;
}

// Alternative version with runtime type checking using type guard
function parseResponseSafe<T>(
    response: Response<any>, 
    validator: (data: any) => boolean
): Response<T> | null {
    if (!validator(response.data)) {
        console.error("Data validation failed");
        return null;
    }
    
    return {
        status: response.status,
        message: response.message,
        data: response.data as T,
        timestamp: response.timestamp
    };
}

// Type guards for validation
function isUserData(data: any): data is UserData {
    return data && 
           typeof data.id === 'number' && 
           typeof data.username === 'string' && 
           typeof data.email === 'string';
}

function isProductData(data: any): data is ProductData {
    return data && 
           typeof data.sku === 'string' && 
           typeof data.name === 'string' && 
           typeof data.price === 'number';
}

