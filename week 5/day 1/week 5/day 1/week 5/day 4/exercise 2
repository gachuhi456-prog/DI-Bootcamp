// Generic class Repository with type assertions
class Repository<T> {
    private items: Map<string, T> = new Map();
    private idCounter: number = 0;

    // Add item with auto-generated or provided key
    add(item: T, key?: string): string {
        const itemKey = key || this.generateId();
        this.items.set(itemKey, item);
        return itemKey;
    }

    // Retrieve item with type assertion
    retrieve(key: string): T {
        const item = this.items.get(key);
        
        // Type assertion: we assert that item is definitely T
        // If not found, we throw an error or return a default
        if (item === undefined) {
            throw new Error(`Item with key "${key}" not found`);
        }
        
        // Type assertion to ensure TypeScript knows this is T
        return item as T;
    }

    // Safe retrieve with type assertion and null check
    retrieveSafe(key: string): T | null {
        const item = this.items.get(key);
        return (item as T | undefined) ?? null;
    }

    // List all items with type assertions
    list(): Array<{ key: string; item: T }> {
        const result: Array<{ key: string; item: T }> = [];
        
        this.items.forEach((value, key) => {
            // Type assertion ensures value is treated as T
            result.push({
                key: key,
                item: value as T
            });
        });
        
        return result;
    }

    // Update item with type assertion
    update(key: string, updates: Partial<T>): T {
        const existing = this.items.get(key);
        
        if (!existing) {
            throw new Error(`Item with key "${key}" not found`);
        }
        
        // Type assertion for the merged object
        const updated = { ...existing, ...updates } as T;
        this.items.set(key, updated);
        
        return updated;
    }

    // Delete item
    delete(key: string): boolean {
        return this.items.delete(key);
    }

    // Check if exists
    exists(key: string): boolean {
        return this.items.has(key);
    }

    // Get count
    count(): number {
        return this.items.size;
    }

    private generateId(): string {
        return `item_${++this.idCounter}`;
    }
}

// Define entity interfaces
interface Employee {
    id: string;
    name: string;
    department: string;
    salary: number;
}

interface Task {
    title: string;
    description: string;
    completed: boolean;
    dueDate: Date;
}

// Test with Employee type
const employeeRepo = new Repository<Employee>();

const empKey1 = employeeRepo.add({
    id: "E001",
    name: "Sarah Connor",
    department: "Engineering",
    salary: 85000
});

const empKey2 = employeeRepo.add({
    id: "E002",
    name: "John Smith",
    department: "Marketing",
    salary: 65000
}, "custom-key");

console.log("Employee Keys:", empKey1, empKey2);

// Retrieve with type assertion (returns exact type)
const employee = employeeRepo.retrieve(empKey1);
console.log("Retrieved Employee:", employee);
console.log("Employee Name:", employee.name); // TypeScript knows this is string
console.log("Employee Salary:", employee.salary); // TypeScript knows this is number

// Safe retrieve
const safeEmployee = employeeRepo.retrieveSafe("non-existent");
console.log("Safe Retrieve (null):", safeEmployee);

// List all
console.log("All Employees:", employeeRepo.list());

// Update
const updated = employeeRepo.update(empKey1, { salary: 90000 });
console.log("Updated Employee:", updated);

