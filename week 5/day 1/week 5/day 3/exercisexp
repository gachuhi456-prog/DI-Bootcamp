class Employee {
  // Properties are defined directly in the constructor for shorthand
  constructor(
    private name: string,
    private salary: number,
    public position: string,
    protected department: string
  ) {}

  public getEmployeeInfo(): string {
    // We can access private and protected properties here
    return `Name: ${this.name}, Position: ${this.position}`;
  }
}

// Usage
const emp = new Employee("Alice Smith", 60000, "Developer", "IT");
console.log(emp.getEmployeeInfo()); // Output: Name: Alice Smith, Position: Developer

// Note: Trying to access emp.name or emp.salary outside the class would cause an error.
// Note: Trying to access emp.department outside the class or its subclasses would cause an error.

class Product {
  constructor(
    public readonly id: number,
    public name: string,
    public price: number
  ) {}

  public getProductInfo(): string {
    return `Product: ${this.name}, Price: $${this.price}`;
  }
}

const product = new Product(101, "Laptop", 999.99);
console.log(product.getProductInfo()); // Output: Product: Laptop, Price: $999.99

console.log(`Initial ID: ${product.id}`);

